# =============================================================================
# sn-47-agent environment (copy to .env and fill secrets)
# =============================================================================

# --- Hugging Face ---
HF_TOKEN=

# --- Weights & Biases (real-time validator log source, NO API key needed for public runs) ---
# Public project open-evolai/evol-validator is readable via W&B public GraphQL.
# HTML page scraping does NOT work (React SPA). public_graphql is the correct no-key method.
WANDB_API_KEY=
WANDB_FETCH_MODE=auto
# auto = public_graphql when no API key, api when WANDB_API_KEY is set
# WANDB_FETCH_MODE=public_graphql
WANDB_RUN_URL=https://wandb.ai/open-evolai/evol-validator/runs/ya596ynd/logs
WANDB_ENTITY=open-evolai
WANDB_PROJECT=evol-validator
WANDB_RUN_ID=ya596ynd
WANDB_LOG_TAIL_LINES=8000
WANDB_CACHE_DIR=/root/sn47/sn-47-agent/.wandb_cache
WANDB_MIRROR_TO_LOCAL_LOG=true

# --- hf_model_ops_bot: download source model ---
DOWNLOAD_USERNAME=
DOWNLOAD_MODEL_NAME=
DOWNLOAD_TARGET_DIR=/root/sn47/sn-47-agent/models

# --- hf_model_ops_bot: upload destination repo ---
UPLOAD_USERNAME=
UPLOAD_MODEL_NAME=evolai-transformer-1
UPLOAD_SOURCE_DIR=

# --- On-chain registration ---
REGISTER_TRACK=transformer
REGISTER_WALLET_NAME=
REGISTER_HOTKEY=
REGISTER_NETUID=47
REGISTER_WALLET_PATH=~/.bittensor/wallets
REGISTER_REVISION=auto

# --- hf_model_ops_bot steps ---
RUN_DOWNLOAD=true
RUN_UPLOAD=true
RUN_REGISTER=true
WATCH_MODE=false
WATCH_POLL_SECONDS=60
WATCH_ERROR_SLEEP_SECONDS=30
STATE_FILE_PATH=/root/sn47/sn-47-agent/.hf_model_ops_state.json
REGISTER_REPO_ID=

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# full_auto_uid_bot.py — train → upload → register
# =============================================================================

AUTO_UID=93
AUTO_NETWORK=finney
AUTO_NETUID=47
# Local mirror of W&B logs (optional debug copy)
AUTO_LOG_FILE=/root/sn47/sn-47-agent/log.md
LOG_SOURCE=wandb
AUTO_WORK_DIR=/root/sn47/sn-47-agent
AUTO_CHALLENGE_JSON=/root/sn47/sn-47-agent/challenge_latest.json
AUTO_PREPARE_OUT_DIR=/root/sn47/sn-47-agent/cpu_pass_all_data
AUTO_EVAL_JSON=/root/sn47/sn-47-agent/latest_eval_record.json
AUTO_SUMMARY_JSON=/root/sn47/sn-47-agent/full_auto_summary.json
AUTO_MODEL_DIR=/root/sn47/sn-47-agent/models/evolai_test_challenge
AUTO_STATE_FILE=/root/sn47/sn-47-agent/.full_auto_uid_state.json

AUTO_WATCH_MODE=true
AUTO_WATCH_POLL_SECONDS=15
AUTO_WATCH_ERROR_SLEEP_SECONDS=30
AUTO_SKIP_DUPLICATE_EVAL=true

# --- Lock-window protection ---
# Lock timing: dynamic = parse W&B logs (slot + lock events); fixed = use interval only
LOCK_TIMING_MODE=dynamic
VALIDATOR_EVAL_INTERVAL_S=720
LOCK_RISK_BUDGET_FRACTION=0.40
MAX_PIPELINE_SECONDS=0
AUTO_ABORT_ON_HIGH_LOCK_RISK=true
AUTO_ABORT_ON_MEDIUM_LOCK_RISK=true
AUTO_FAST_TRAIN_ON_LOCK_RISK=true

# --- GPU training ---
TRAIN_DEVICE=cuda
TRAIN_ENABLED=true
TRAIN_CMD=python3 /root/sn47/sn-47-agent/train_cpu_real.py --uid {UID} --challenge-json {CHALLENGE_JSON} --eval-json {EVAL_JSON} --prep-out-dir {PREP_OUT_DIR} --model-dir {MODEL_DIR} --report-json {TRAIN_REPORT_JSON} --focus-file {FOCUS_FILE} --train-mode super_light --device cuda --max-steps 10 --lr 5e-5 --max-seq-len 256

FAST_TRAIN_CMD=python3 /root/sn47/sn-47-agent/train_cpu_real.py --uid {UID} --challenge-json {CHALLENGE_JSON} --eval-json {EVAL_JSON} --prep-out-dir {PREP_OUT_DIR} --model-dir {MODEL_DIR} --report-json {TRAIN_REPORT_JSON} --focus-file {FOCUS_FILE} --train-mode super_light --device cuda --max-steps 6 --lr 8e-5 --max-seq-len 256

# --- Gate / KL checks (validator-matching KL via evaluate_with_side_quests) ---
GATE_CHECK_ENABLED=true
GATE_REQUIRED_IMPROVEMENT=0.02
GATE_FAIL_ACTION=abort
TRAIN_UNTIL_PASS_ENABLED=true
TRAIN_UNTIL_PASS_MAX_ROUNDS=8
TARGET_VALIDATOR_UID=6
KL_EVAL_VALIDATOR_UIDS=6
KL_EVAL_ENABLED=true
KL_EVAL_REF_MODEL=Qwen/Qwen3.5-9B
KL_EVAL_REF_TOKENIZER=Qwen/Qwen3.5-9B
# vLLM MC-KL (validator-identical). Install: bash /root/sn47/sn-47-agent/scripts/setup-vllm.sh
# RunPod without nvcc: use inprocess (saves ~4 min per KL eval vs failed vLLM startup)
# KL_EVAL_REF_MODE=inprocess
# KL_EVAL_START_VLLM_REF=false
KL_EVAL_REF_MODE=vllm
KL_EVAL_FALLBACK_INPROCESS=true
KL_EVAL_START_VLLM_REF=true
# CUDA toolkit for vLLM flashinfer JIT (optional if nvcc is on PATH)
# CUDA_HOME=/usr/local/cuda-12.8
KL_EVAL_MAX_LENGTH=8192
KL_EVAL_KL_MAX_NEW_TOKENS=512
KL_EVAL_LIMIT_PER_VALIDATOR=20
KL_EVAL_DEVICE=cuda
KL_EVAL_PROGRESS_EVERY=5
KL_EVAL_DATA_SUFFIX=_next
# vLLM ref server — install with: bash /root/sn47/sn-47-agent/scripts/setup-vllm.sh
VLLM_EXECUTABLE=/root/sn47/sn-47-agent/vllm_env/bin/vllm
VLLM_REF_URL=
VLLM_REF_PORT=8002
VLLM_REF_GPU_INDEX=0
VLLM_REF_GPU_MEMORY_UTILIZATION=0.50
VLLM_REF_MAX_MODEL_LEN=4096

UPLOAD_COMMIT_MESSAGE=Auto train+publish via full_auto_uid_bot
