HF_TOKEN=

# Download settings
DOWNLOAD_USERNAME=
DOWNLOAD_MODEL_NAME=
DOWNLOAD_TARGET_DIR=/root/sn47/sn-47-agent/models

# Upload settings
UPLOAD_USERNAME=
# Existing model repo name to commit into (no auto-create).
UPLOAD_MODEL_NAME=evolai-transformer-1
# Local folder to upload. If blank, defaults to downloaded model directory.
UPLOAD_SOURCE_DIR=

# EvolAI register settings
REGISTER_TRACK=transformer
REGISTER_WALLET_NAME=
REGISTER_HOTKEY=
REGISTER_NETUID=47

# Which steps to run
RUN_DOWNLOAD=true
RUN_UPLOAD=true
RUN_REGISTER=true
# Watch mode: if true, detect source model new commit and auto-run pipeline.
WATCH_MODE=false
WATCH_POLL_SECONDS=60
WATCH_ERROR_SLEEP_SECONDS=30
STATE_FILE_PATH=/root/sn47/sn-47-agent/.hf_model_ops_state.json
# Optional for register-only mode (when RUN_UPLOAD=false):
REGISTER_REPO_ID=
REGISTER_REVISION=

# Telegram notification settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
