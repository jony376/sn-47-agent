# Local model folder to upload if UPLOAD_SOURCE_DIR is blank.
AUTO_MODEL_DIR=/root/sn47/sn-47-agent/models/evolai_test_challenge

# Training control
TRAIN_ENABLED=true
# Optional shell command. Placeholders:
# {UID} {CHALLENGE_JSON} {EVAL_JSON} {PREP_OUT_DIR} {MODEL_DIR} {MODEL_REPO} {MODEL_REVISION}
TRAIN_CMD=python3 /root/sn47/sn-47-agent/train_cpu_real.py --uid {UID} --challenge-json {CHALLENGE_JSON} --eval-json {EVAL_JSON} --prep-out-dir {PREP_OUT_DIR} --model-dir {MODEL_DIR} --report-json {TRAIN_REPORT_JSON} --train-mode lm_head --max-steps 30 --lr 5e-5 --max-seq-len 512

# Upload / register extras
UPLOAD_COMMIT_MESSAGE=Auto train+publish via full_auto_uid_bot
REGISTER_WALLET_PATH=~/.bittensor/wallets
REGISTER_REVISION=main
GATE_CHECK_ENABLED=true
GATE_REQUIRED_IMPROVEMENT=0.0
GATE_FAIL_ACTION=abort
