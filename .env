# Existing model repo name to commit into (no auto-create).
UPLOAD_MODEL_NAME=evolai-tf-model
# Local folder to upload. If blank, defaults to downloaded model directory.
UPLOAD_SOURCE_DIR=

# EvolAI register settings
REGISTER_TRACK=transformer
REGISTER_WALLET_NAME=phoenix713
REGISTER_HOTKEY=phoenix713
REGISTER_NETUID=47

# Which steps to run
RUN_DOWNLOAD=true
RUN_UPLOAD=true
RUN_REGISTER=true
# Watch mode: if true, detect source model new commit and auto-run pipeline.
WATCH_MODE=true
WATCH_POLL_SECONDS=60
STATE_FILE_PATH=/root/sn47/sn-47-agent/.hf_model_ops_state.json
# Optional for register-only mode (when RUN_UPLOAD=false):
REGISTER_REPO_ID=
REGISTER_REVISION=

# Telegram notification settings
TELEGRAM_BOT_TOKEN=8666228137:AAF_NLMrow4cDf3uEJCl3JY7DeBHtovd1TU
TELEGRAM_CHAT_ID=8766781014

# Full auto UID bot settings (sn-47-agent/full_auto_uid_bot.py)
AUTO_UID=93
AUTO_NETWORK=finney
AUTO_NETUID=47
AUTO_LOG_FILE=/root/sn47/sn-47-agent/log.md
AUTO_WORK_DIR=/root/sn47/sn-47-agent
AUTO_CHALLENGE_JSON=/root/sn47/sn-47-agent/challenge_latest.json
AUTO_PREPARE_OUT_DIR=/root/sn47/sn-47-agent/cpu_pass_all_data
AUTO_EVAL_JSON=/root/sn47/sn-47-agent/latest_eval_record.json
